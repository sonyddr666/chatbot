# ═══════════════════════════════════════════════════════════════
# Chatbot — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# ─── Provedor LLM ─────────────────────────────────────────────
# Opções: openai | anthropic | ollama | custom_openai
LLM_PROVIDER=custom_openai

# ─── Custom OpenAI-compatible (OpenCode Zen) ──────────────────
# Perfis disponíveis:
#   "zen-openai"    → GPT-5.5, GPT-5.2, GPT-5 (Responses API)
#   "zen-anthropic" → Claude Sonnet 5, Opus 4.8, Qwen 3.7
#   "zen-free"      → DeepSeek V4 Flash Free, Mimo V2.5 Free
#   "zen-paid"      → DeepSeek V4 Flash/Pro, GLM 5.2, Kimi K2
#   "go-chat"       → DeepSeek V4, Mimo V2.5, GLM 5.2 (Go tier)
#   "go-anthropic"  → MiniMax M3, Qwen 3.7 (Go tier)
CUSTOM_PROFILE=opencode-zen-free

# Para sobrescrever manualmente (opcional):
# CUSTOM_API_KEY=sk-your-key
# CUSTOM_BASE_URL=https://opencode.ai/zen/v1
# CUSTOM_MODEL=deepseek-v4-flash-free

# ─── OpenAI nativo ────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic nativo ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ─── Ollama (local) ───────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ─── Embeddings ───────────────────────────────────────────────
# OpenAI ou HuggingFace (local, gratuito)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector DB ────────────────────────────────────────────────
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/chatbot.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/chatbot
AUTH_SECRET_KEY=
USER_DATA_DIR=./data/users

# Bootstrap seguro: o administrador e criado apenas uma vez e a senha nao e
# redefinida nos proximos boots. Use uma senha com pelo menos 12 caracteres.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
# false fecha novas solicitacoes; true permite solicitar conta, sempre pendente de aprovacao admin.
ALLOW_REGISTRATION=false

# ─── Redis (opcional) ─────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# ─── App ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_PORT=8000
FRONTEND_HOST_PORT=3100
MAX_UPLOAD_SIZE_MB=10
ENABLE_MODERATION=true
ENABLE_MULTILANG=true
ENABLE_RAG=true
RATE_LIMIT_PER_MINUTE=30

# Perplexo HTTP skill server
PERPLEXO_BASE_URL=https://api.ghost1.cloud
MCP_API_KEY=
PERPLEXO_TIMEOUT_SECONDS=25

# Inworld TTS: vozes do sistema e clones IVC da workspace da chave.
# A chave permanece somente no backend/Coolify.
INWORLD_API_KEY=
INWORLD_TTS_BASE_URL=https://api.inworld.ai
INWORLD_TTS_MODEL=inworld-tts-2
INWORLD_TTS_DEFAULT_VOICE=
INWORLD_TTS_TIMEOUT_SECONDS=20
INWORLD_TTS_VOICE_CACHE_SECONDS=300
INWORLD_TTS_AUDIO_CACHE_SECONDS=300
INWORLD_TTS_AUDIO_CACHE_MAX_ITEMS=256

# Codex: parser SSE tipado, com rollback imediato para o parser legado.
CODEX_SSE_ENABLED=true
# normal | thinking | live
CODEX_RESPONSE_MODE_DEFAULT=normal
